# ============================================================================
# .env UNICO do SMS Sender (TextBee self-hosted).
# Copie para .env e preencha:  cp .env.example .env
# No Dokploy: cole TODO o conteudo no campo "Environment" do servico Compose.
# (o docker-compose usa este arquivo tanto pra substituicao ${VAR} quanto pra
#  injetar as vars nos containers api/web.)
# ============================================================================

# ---- MongoDB ----
MONGO_ROOT_USER=adminUser
MONGO_ROOT_PASS=troque-por-uma-senha-forte

# ---- Dominios ----
WEB_URL=https://app.seu-dominio.com
API_BASE_URL=https://api.seu-dominio.com/api/v1/
FRONTEND_URL=https://app.seu-dominio.com

# ---- API (NestJS) ----
# OBS: MONGO_URI e DATABASE_URL NAO ficam aqui — o compose deriva ambas do
# MONGO_ROOT_USER/MONGO_ROOT_PASS automaticamente (sem risco de mismatch).
JWT_SECRET=troque-por-uma-string-aleatoria-forte
JWT_EXPIRATION=60d
USE_SMS_QUEUE=false
REDIS_URL=redis://textbee-redis:6379
CLOUDFLARE_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ---- Firebase (push FCM) — da service account JSON ----
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
# chave numa linha so, com \n literais (sem aspas)
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_C509_CERT_URL=

# ---- Web (Next.js) ----
AUTH_SECRET=troque-por-uma-string-aleatoria-32
NEXTAUTH_SECRET=troque-por-uma-string-aleatoria-32
NEXTAUTH_URL=https://app.seu-dominio.com
NEXT_PUBLIC_API_BASE_URL=https://api.seu-dominio.com/api/v1
NEXT_PUBLIC_SITE_URL=https://app.seu-dominio.com
# vazio = usa /sms-sender.apk servido pelo proprio web (APK buildado na imagem)
NEXT_PUBLIC_APK_DOWNLOAD_URL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ---- Build do APK no Docker ----
# Local: deixe vazio (o google-services.json esta em android/app/).
# Dokploy/CI (sem o arquivo): cole o base64:
#   base64 -w0 android/app/google-services.json
GOOGLE_SERVICES_JSON_B64=
