# ===========================================================================
# .env da raiz — lido pelo docker-compose, pelo service-up.sh e pelo build do APK.
# Copie para .env e preencha:  cp .env.example .env
# ===========================================================================

# Credenciais do MongoDB usadas pelo container textbee-db e mongo-express.
# Precisam ser as MESMAS usadas em api/.env (MONGO_URI) e web/.env (DATABASE_URL).
MONGO_ROOT_USER=adminUser
MONGO_ROOT_PASS=troque-por-uma-senha-forte

# Portas expostas no host (defaults do compose). Descomente para alterar.
# MONGO_PORT=27018
# MONGO_EXPRESS_PORT=8081
# REDIS_PORT=6379

# NAO defina PORT aqui: a substituicao ${PORT} no compose vale para api e web
# ao mesmo tempo e causaria conflito (api=3001, web=3000 ja sao os defaults).

# ---------------------------------------------------------------------------
# Dominios publicos (unico lugar pra editar).
# API_BASE_URL  -> usado pelo build do APK (precisa terminar com /api/v1/).
# WEB_URL       -> usado pelo service-up.sh pra exibir o destino do tunel.
# Aponte seu tunel/proxy:  WEB_URL -> porta 3000 (dashboard) | API -> porta 3001
API_BASE_URL=https://api.seu-dominio.com/api/v1/
WEB_URL=https://app.seu-dominio.com
